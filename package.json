{
  "name": "assumer-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit --pretty false --incremental false",
    "test": "node --test --test-reporter=spec",
    "test:fairness": "node --test --test-name-pattern=counterfactual",
    "fairness:report": "node scripts/fairness-report.mjs",
    "adverse-impact:report": "node scripts/adverse-impact-report.mjs",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run typecheck && npm run lint",
    "optimize:laptop": "gltf-transform draco public/laptop.glb public/laptop.draco.glb --method edgebreaker --encode-speed 5 --decode-speed 7"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.57.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
