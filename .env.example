# AssumerAI environment configuration (example).
# Copy to .env.local and fill in real values. Never commit secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key: server-only. Required in production for server-authoritative
# interview state and evaluator-run persistence (these tables are service-role write only).
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (planner / interviewer / evaluator / resume parsing) ---
# Every Anthropic call degrades to a deterministic fallback when unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_MODEL_FALLBACKS=
ANTHROPIC_INTERVIEW_MODEL=
ANTHROPIC_INTERVIEW_MODEL_FALLBACKS=
ANTHROPIC_INTERVIEWER_MODEL=
ANTHROPIC_INTERVIEWER_MODEL_FALLBACKS=
ANTHROPIC_EVALUATOR_MODEL=
ANTHROPIC_EVALUATOR_MODEL_FALLBACKS=

# --- Deepgram (live transcription) ---
DEEPGRAM_KEY=

# --- Voice / TTS (optional; default mock is offline-safe) ---
TTS_PROVIDER=mock
LIVE_INTERVIEW_PROVIDER=mock
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# --- Resume ingestion ---
# auto = Anthropic when configured, local deterministic parser otherwise.
RESUME_PARSER_PROVIDER=auto
# Default 8MB; file content is verified by magic bytes (PDF %PDF, DOCX PK), not extension.
RESUME_UPLOAD_MAX_BYTES=8388608
RESUME_UPLOAD_ALLOWED_EXTENSIONS=
RESUME_UPLOAD_ALLOWED_MIME_TYPES=
RETENTION_DAYS_RAW_CV=30
# Raw interview media is deleted this many hours after processing (default 24).
RETENTION_HOURS_RAW_MEDIA=24

# --- Cron jobs ---
# Shared secret for /api/cron/* routes (Vercel sends it as Authorization: Bearer).
CRON_SECRET=

# --- Rate limiting (sliding window, Postgres-backed; safe defaults) ---
RATE_LIMIT_TURN_PER_MINUTE=10
RATE_LIMIT_RESUME_UPLOAD_PER_HOUR=5
RATE_LIMIT_DEEPGRAM_TOKEN_PER_HOUR=10

# --- LLM budget guard ---
# Estimated daily Anthropic spend (EUR). At or above this, LLM routes return 503
# until the UTC day resets; deterministic fallbacks keep working. Default 25.
LLM_DAILY_BUDGET_EUR=25

# --- Site / dev toggles ---
SITE_PASSWORD=
# Allows the candidate flow to run without Supabase auth in local development only.
ASSUMERAI_ALLOW_LOCAL_CANDIDATE_FALLBACK=false
# Optional path to a governed university ranking snapshot dataset.
ASSUMERAI_UNIVERSITY_RANKING_SNAPSHOT=
